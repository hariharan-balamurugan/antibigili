# Application
VITE_APP_NAME=antibigili
VITE_APP_ENV=development

# API Configuration
VITE_API_URL=http://localhost:5000/api

# JWT Secret (for development only, use strong secret in production)
VITE_JWT_SECRET=your-secret-key-change-me-in-production

# MongoDB Connection (if backend is Node.js)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/antibigili?retryWrites=true&w=majority

# Authentication
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
